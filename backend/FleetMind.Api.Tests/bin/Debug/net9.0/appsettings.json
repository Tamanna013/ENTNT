{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AiProvider": {
    "Provider": "None",
    "ModelDeploymentName": "gpt-4o",
    "MaxTokens": 1000,
    "TimeoutSeconds": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "BackgroundServices": {
    "DelayedVoyageCheckIntervalMinutes": 15,
    "MaintenanceOverdueCheckIntervalMinutes": 15,
    "ExpiringCertificationCheckIntervalMinutes": 60
  },
  "AiRateLimit": {
    "MaxRequestsPerUserPerHour": 20
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=...;Database=...;...;Min Pool Size=5;Max Pool Size=100;"
  },
  "Jwt": {
    "Issuer": "FleetMindAI",
    "Audience": "FleetMindAIClient",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "FileStorage": {
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [".pdf", ".jpg", ".jpeg", ".png", ".docx", ".xlsx"],
    "LocalStoragePath": "App_Data/uploads"
  },
  "Cache": {
    "DefaultAbsoluteExpirationMinutes": 5,
    "AnalyticsExpirationMinutes": 15
  },
  "RateLimiting": {
    "AuthEndpointsPermitLimit": 5,
    "AuthEndpointsWindowMinutes": 1,
    "GeneralApiPermitLimit": 100,
    "GeneralApiWindowMinutes": 1
  },
  "AccountLockout": {
    "MaxFailedAttempts": 5,
    "LockoutDurationMinutes": 15
  },
  "SecurityHeaders": {
    "EnableHsts": true,
    "HstsMaxAgeDays": 365
  }
}
